{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Edit",
      "Write",
      "Bash(python3 -m pytest *)",
      "Bash(python3 -m ruff *)",
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(curl *)",
      "Bash(pip install *)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push * --force*)",
      "Bash(git push -f*)",
      "Bash(git push * -f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(git checkout -- .)",
      "Bash(rm -rf /)*",
      "Bash(rm -rf ~)*",
      "Bash(curl *| bash*)",
      "Bash(curl *| sh*)",
      "Bash(wget *| bash*)",
      "Bash(wget *| sh*)"
    ]
  },
  "env": {
    "FORGE_DB_PATH": "/opt/project-forge/data/forge.db",
    "FORGE_PORT": "55443"
  },
  "preferences": {
    "agentMode": true,
    "autoApprove": false
  }
}
